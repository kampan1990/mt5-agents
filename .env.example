# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional
YOUTUBE_COOKIES_PATH=          # Path to cookies.txt for age-restricted videos
BATCH_SIZE=5                   # Videos per Claude API call
MAX_RETRIES=3                  # Retry attempts on API failure
RETRY_BACKOFF_BASE=2           # Exponential backoff base (seconds)
MIN_CONFIDENCE=0.6             # Minimum confidence score to accept a skill
MIN_TRANSCRIPT_WORDS=200       # Skip transcripts shorter than this
MAX_VIDEO_DURATION=10800       # Skip videos longer than 3 hours (seconds)
CLAUDE_MODEL=claude-sonnet-4-6 # Claude model for extraction
CLAUDE_TEMPERATURE=0.1         # Low temperature for deterministic extraction
